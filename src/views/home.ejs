<!DOCTYPE html>
<html lang="pt-BR">
  <%- include('partials/header', { title: 'Explorar Livros' }) %>
<body class="bg-gray-50 flex flex-col min-h-screen">

  <%- include('partials/nav') %>

  <main class="max-w-6xl mx-auto p-6 flex-1 w-full mt-4">
    <div class="flex justify-between items-center mb-8">
      <div>
        <h2 class="text-2xl font-bold text-gray-800">Explorar Acervo</h2>
        <p class="text-sm text-gray-500">Descubra novos títulos adicionados pela comunidade.</p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% if (typeof livros !== 'undefined' && livros && livros.length > 0) { %>
        <% livros.forEach(livro => { %>
          <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-6 hover:shadow-md transition flex flex-col justify-between">
            <div>
              <span class="inline-block bg-indigo-100 text-indigo-800 text-xs px-2.5 py-1 rounded-full font-semibold uppercase tracking-wide mb-3">
                <%= livro.categoria %>
              </span>
              <h3 class="text-xl font-bold text-gray-900 mb-1"><%= livro.titulo %></h3>
              <p class="text-sm text-gray-600 mb-4">Por: <span class="font-medium text-gray-800"><%= livro.autor %></span></p>
              <p class="text-gray-700 text-sm line-clamp-3 mb-4"><%= livro.descricao || 'Sem descrição informada.' %></p>
            </div>
            <div class="border-t pt-4 flex justify-between items-center mt-4">
              <span class="text-xs text-gray-400">Disponível</span>
              <button class="text-indigo-600 text-sm font-semibold hover:underline flex items-center space-x-1">
                <span>Ler Online</span> <span>→</span>
              </button>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-span-full text-center py-16 bg-white rounded-lg shadow-sm border border-gray-200 flex flex-col items-center justify-center">
          <span class="text-4xl mb-3">📖</span>
          <p class="text-gray-500 text-lg font-medium">Nenhum livro cadastrado ainda.</p>
          <p class="text-gray-400 text-sm mt-1 mb-4">Seja o pioneiro e adicione uma nova obra ao sistema.</p>
          <a href="/livros/novo" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded text-sm font-medium transition">Cadastrar Primeiro Livro</a>
        </div>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>

</body>
</html>